# Google Gemini API key (required for RAG report generation)
GOOGLE_API_KEY=your-google-ai-key-here

# Mapbox (required for map tiles and geocoding)
MAPBOX_ACCESS_TOKEN=pk.eyJ-your-token-here

# Copernicus Data Space (required for satellite data validation)
COPERNICUS_USER=your_email@example.com
COPERNICUS_PASSWORD=your_password
